# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your Supabase project credentials.
# ─────────────────────────────────────────────────────────────────────────────

# Supabase Project URL — found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase Anon/Public key — found in: Supabase Dashboard → Settings → API
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Admin panel password  (default: admin1234)
VITE_ADMIN_PASSWORD=admin1234
